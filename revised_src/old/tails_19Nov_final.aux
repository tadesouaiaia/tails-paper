\@writefile{lof}{\contentsline {figure}{\numberline {1}{\ignorespaces {{\bf  Extended Replication} \textbf  {a,} PRS quantile (in 1\% increments) plotted against mean trait value in quantile for four traits with different types of POPout effects in the primary analyses. \textbf  {b,} POPout effect sizes in primary and replication cohorts across the 33 overlapping traits in the All of Us cohort. \textbf  {c,d,} Considering trait tails with significant POPout results in our large European ancestry analysis ('Discovery') as true positives, the percent of tails replicated ($P$ < 0.05) in 100 bootstrapped runs of different sizes (\textbf  {c}) and in the replication datasets (\textbf  {d}). \textbf  {e,f,} Replication here is defined here as a significant Pearson correlation across effect sizes in our bootstrapped subsets (\textbf  {e}) and in the replication datasets (\textbf  {f}). }\relax }}{24}{figure.caption.5}\protected@file@percent }
\newlabel{sup1}{{1}{24}{{{\bf Extended Replication} \textbf {a,} PRS quantile (in 1\% increments) plotted against mean trait value in quantile for four traits with different types of POPout effects in the primary analyses. \textbf {b,} POPout effect sizes in primary and replication cohorts across the 33 overlapping traits in the All of Us cohort. \textbf {c,d,} Considering trait tails with significant POPout results in our large European ancestry analysis ('Discovery') as true positives, the percent of tails replicated ($P$ < 0.05) in 100 bootstrapped runs of different sizes (\textbf {c}) and in the replication datasets (\textbf {d}). \textbf {e,f,} Replication here is defined here as a significant Pearson correlation across effect sizes in our bootstrapped subsets (\textbf {e}) and in the replication datasets (\textbf {f}). }\relax }{figure.caption.5}{}}
