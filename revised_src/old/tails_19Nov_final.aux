\@writefile{lof}{\contentsline {figure}{\numberline {3}{\ignorespaces {{\bf  Tail architecture inferred from siblings.} \textbf  {a,} Schematic of relationships between sibling trait values under tails governed by polygenic (grey), \emph  {de novo} (red) and Mendelian (purple) architecture, where Mendelian here refers to rare (but not \emph  {de novo}) high-impact alleles segregating in families. \textbf  {b,} Index sibling trait quantile (1\% increments) plotted against mean trait value of other (conditional) sibling for the four traits selected with different POPout characteristics (see Fig.2a). \textbf  {c,} POPout $P$-values plotted against STANDout $P$­-values for the 74 traits. Correlation and significance calculated using Pearson. \textbf  {d,} LD score regression \cite  {BulikSullivan2015} SNP-estimated heritability plotted against heritability estimated from sibling pair trait similarity \cite  {Souaiaia2024}. }\relax }}{7}{figure.caption.3}\protected@file@percent }
\newlabel{fig3}{{3}{7}{{{\bf Tail architecture inferred from siblings.} \textbf {a,} Schematic of relationships between sibling trait values under tails governed by polygenic (grey), \emph {de novo} (red) and Mendelian (purple) architecture, where Mendelian here refers to rare (but not \emph {de novo}) high-impact alleles segregating in families. \textbf {b,} Index sibling trait quantile (1\% increments) plotted against mean trait value of other (conditional) sibling for the four traits selected with different POPout characteristics (see Fig.2a). \textbf {c,} POPout $P$-values plotted against STANDout $P$­-values for the 74 traits. Correlation and significance calculated using Pearson. \textbf {d,} LD score regression \cite {BulikSullivan2015} SNP-estimated heritability plotted against heritability estimated from sibling pair trait similarity \cite {Souaiaia2024}. }\relax }{figure.caption.3}{}}
