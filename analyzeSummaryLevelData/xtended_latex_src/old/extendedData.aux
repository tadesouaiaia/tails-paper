\newlabel{xtd2}{{2}{7}{{{\bf Impact on Prediction for Four Traits} Extended analysis from Fig1.c, using PRS to predict trait values in the lower/upper 25\% and 1\% of the distribution. }\relax }{figure.caption.7}{}}
\newlabel{xtd2@cref}{{[figure][2][]2}{[1][7][]7}}
\@writefile{lof}{\contentsline {figure}{\numberline {3}{\ignorespaces {{\bf  Extended Replication} \textbf  {a,} PRS quantile (in 1\% increments) plotted against mean trait value in quantile for four traits with different types of POPout effects in the primary analyses. \textbf  {b,} POPout effect sizes in primary and replication cohorts across the 31 overlapping traits in the All of Us cohort. \textbf  {c,d,} Considering trait tails with significant POPout results in our large European ancestry analysis ('Discovery') as true positives, the percent of tails replicated ($P$ < 0.05) in 100 bootstrapped runs of different sizes (\textbf  {c}) and in the replication datasets (\textbf  {d}). \textbf  {e,f,} Replication here is defined here as a significant Pearson correlation across effect sizes in our bootstrapped subsets (\textbf  {e}) and in the replication datasets (\textbf  {f}). }\relax }}{8}{figure.caption.8}\protected@file@percent }
\newlabel{xtd1}{{3}{8}{{{\bf Extended Replication} \textbf {a,} PRS quantile (in 1\% increments) plotted against mean trait value in quantile for four traits with different types of POPout effects in the primary analyses. \textbf {b,} POPout effect sizes in primary and replication cohorts across the 31 overlapping traits in the All of Us cohort. \textbf {c,d,} Considering trait tails with significant POPout results in our large European ancestry analysis ('Discovery') as true positives, the percent of tails replicated ($P$ < 0.05) in 100 bootstrapped runs of different sizes (\textbf {c}) and in the replication datasets (\textbf {d}). \textbf {e,f,} Replication here is defined here as a significant Pearson correlation across effect sizes in our bootstrapped subsets (\textbf {e}) and in the replication datasets (\textbf {f}). }\relax }{figure.caption.8}{}}
\newlabel{xtd1@cref}{{[figure][3][]3}{[1][8][]8}}
