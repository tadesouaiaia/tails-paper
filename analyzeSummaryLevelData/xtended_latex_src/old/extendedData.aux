\@writefile{lof}{\contentsline {figure}{\numberline {1}{\ignorespaces {{\bf  Replication of Sanjak \cite  {Sanjak2018} lifetime reproductive success results.} Comparison of results among overlapping traits (without sex differences) shows replication (i.e. statistically significant parameters included in our model) for 19 of 20 parameters. The only exception is \textit  {Body Fat}, in which Sanjak et al \cite  {Sanjak2018} reported a positive stabilising result in males and females, while we selected a neutral stabilising model in the pooled sample. }\relax }}{16}{figure.caption.16}\protected@file@percent }
\newlabel{sup1}{{1}{16}{{{\bf Replication of Sanjak \cite {Sanjak2018} lifetime reproductive success results.} Comparison of results among overlapping traits (without sex differences) shows replication (i.e. statistically significant parameters included in our model) for 19 of 20 parameters. The only exception is \textit {Body Fat}, in which Sanjak et al \cite {Sanjak2018} reported a positive stabilising result in males and females, while we selected a neutral stabilising model in the pooled sample. }\relax }{figure.caption.16}{}}
\newlabel{sup1@cref}{{[figure][1][]1}{[1][16][]16}}
\@writefile{lof}{\contentsline {figure}{\numberline {2}{\ignorespaces {\bf  BIC model selection sensitivity analysis.} \textbf  {a,} For 17 of 74 traits, the top model selected using BIC was not significantly better fitting than the second best model. \textbf  {b,} Association between BIC selected models of selection and POPout effects (top models). \textbf  {c,} Association between BIC selected models of selection and POPout effects after instead using the second best model for the 17 traits in which the top model was not significantly better fitting than the second best model. \relax }}{17}{figure.caption.17}\protected@file@percent }
\newlabel{sup2}{{2}{17}{{\bf BIC model selection sensitivity analysis.} \textbf {a,} For 17 of 74 traits, the top model selected using BIC was not significantly better fitting than the second best model. \textbf {b,} Association between BIC selected models of selection and POPout effects (top models). \textbf {c,} Association between BIC selected models of selection and POPout effects after instead using the second best model for the 17 traits in which the top model was not significantly better fitting than the second best model. \relax }{figure.caption.17}{}}
