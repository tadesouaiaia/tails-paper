\@writefile{lof}{\contentsline {figure}{\numberline {2}{\ignorespaces \footnotesize  {{\bf  Population-level data analyses for rare variants of large effect affecting the tails of trait distributions.} \textbf  {(a)} PRS quantile (in 1\% increments) plotted agaisnt mean trait value in quantile for four traits with different types of PRS tail regression (clockwise: No Tail Regression, Upper Tail, Lower Tail, Dual Tail). \textbf  {(b)} PRS-test tail effect sizes and \textbf  {\leavevmode {\color {red}NEED: 95\% confidence intervals}} in the upper and lower 1\% tails for all traits (of the 75 passing QC) which exhibit significant regression to the mean in one or both tails at FDR of 0.05. \textbf  {(c)} Trumpet plots (minor allele frequency v effect size) of genome-wide significant variants for traits shown in (a). \textbf  {(d)} PRS-test tail effect sizes plotted against number of genome-wide significant variants with MAF<1\% for X traits with overlapping exome sequence results. For upper tails positive variant effects are counted and for lower tails negative variant effects are counted. Correlation and significance calculated using Spearman rank correlation. \textbf  {(e)} Age of menopause: PRS quantile v trait mean and trumpet plot. }\relax }}{4}{figure.caption.2}\protected@file@percent }
\newlabel{fig:prs}{{2}{4}{\footnotesize {{\bf Population-level data analyses for rare variants of large effect affecting the tails of trait distributions.} \textbf {(a)} PRS quantile (in 1\% increments) plotted agaisnt mean trait value in quantile for four traits with different types of PRS tail regression (clockwise: No Tail Regression, Upper Tail, Lower Tail, Dual Tail). \textbf {(b)} PRS-test tail effect sizes and \need {95\% confidence intervals} in the upper and lower 1\% tails for all traits (of the 75 passing QC) which exhibit significant regression to the mean in one or both tails at FDR of 0.05. \textbf {(c)} Trumpet plots (minor allele frequency v effect size) of genome-wide significant variants for traits shown in (a). \textbf {(d)} PRS-test tail effect sizes plotted against number of genome-wide significant variants with MAF<1\% for X traits with overlapping exome sequence results. For upper tails positive variant effects are counted and for lower tails negative variant effects are counted. Correlation and significance calculated using Spearman rank correlation. \textbf {(e)} Age of menopause: PRS quantile v trait mean and trumpet plot. }\relax }{figure.caption.2}{}}
\newlabel{fig:prs@cref}{{[figure][2][]2}{[1][3][]4}}
