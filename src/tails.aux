\@writefile{lof}{\contentsline {figure}{\numberline {5}{\ignorespaces \footnotesize  {{\bf  Replication results in UKB non-European samples, All of Us European ancestry samples and bootstrap analyses of UKB European samples.} \textbf  {(a)} PRS quantile (in 1\% increments) plotted agaisnt mean trait value in quantile in UKB European ancestry samples, UKB non-European ancestry samples and All Of Us European ancestry samples for four traits with different types of PRS tail regression. \textbf  {(b)} PRS-test tail effect estimates in UKB European ancestry samples, UKB non-European ancestry samples and All of Us Euroepan ancestry samples for all 25 traits overlapping with All of US and pass PRS-test quality control in the three cohorts. \textbf  {(c)} Simulated Signal Replication: Increasing larger subsets were sampled and the replicability relative to our UKB result was calculated \textbf  {(d)} Same thing but correlation. \textbf  {(e)}. \textbf  {(f)} PRS-test effect sizes estimated in: UKB European ancestry samples v UKB non-European ancestry samples for X traits passing PRS-test QC in both cohorts. \textbf  {(g)}. \textbf  {(h)} PRS-test effect sizes estimated in: UKB European ancestry samples v All Of Us European ancestry samples for 24 overlapping traits passing PRS-test QC in both cohorts.} \relax }}{9}{figure.caption.5}\protected@file@percent }
\newlabel{fig:rep}{{5}{9}{\footnotesize {{\bf Replication results in UKB non-European samples, All of Us European ancestry samples and bootstrap analyses of UKB European samples.} \textbf {(a)} PRS quantile (in 1\% increments) plotted agaisnt mean trait value in quantile in UKB European ancestry samples, UKB non-European ancestry samples and All Of Us European ancestry samples for four traits with different types of PRS tail regression. \textbf {(b)} PRS-test tail effect estimates in UKB European ancestry samples, UKB non-European ancestry samples and All of Us Euroepan ancestry samples for all 25 traits overlapping with All of US and pass PRS-test quality control in the three cohorts. \textbf {(c)} Simulated Signal Replication: Increasing larger subsets were sampled and the replicability relative to our UKB result was calculated \textbf {(d)} Same thing but correlation. \textbf {(e)}. \textbf {(f)} PRS-test effect sizes estimated in: UKB European ancestry samples v UKB non-European ancestry samples for X traits passing PRS-test QC in both cohorts. \textbf {(g)}. \textbf {(h)} PRS-test effect sizes estimated in: UKB European ancestry samples v All Of Us European ancestry samples for 24 overlapping traits passing PRS-test QC in both cohorts.} \relax }{figure.caption.5}{}}
