\@writefile{lof}{\contentsline {figure}{\numberline {3}{\ignorespaces \footnotesize  {{\bf  Selection analyses in real and simulated data.} \textbf  {(a)} Residualised trait value plotted against relative lifetime reproductive success for 16 \textbf  {\leavevmode {\color {red}NEED: cherry picked traits}}, quadratic best fit to the data is shown by dashed lines. \textbf  {(b)} Number of traits with inferred type of PRS tail regression and inferred type of selection for 75 UKB traits passing QC. Tail regression is inferred if tail effect is significant at an FDR of 0.05. \textbf  {(c)} Spearman rank correlation between standardised mean proxy measures of fitness of individuals in the upper and lower 1\% tails and PRS-test effect size for the corresponding tail across 75 traits in UKB passing QC. \textbf  {(d)} \textbf  {\leavevmode {\color {red}NEED: not sure this is needed}}. \textbf  {(e)} Trumpet plots (minor allele frequency v effect size) for simulated data without and with selection. All variants are included in the plot. \textbf  {(e)} PRS quantile (in 1\% increments) plotted agaisnt mean trait value in quantile in simulated data without and with selection. PRS calculated from all variants with MAF>1\%. }\relax }}{5}{figure.caption.3}\protected@file@percent }
\newlabel{fig:evo}{{3}{5}{\footnotesize {{\bf Selection analyses in real and simulated data.} \textbf {(a)} Residualised trait value plotted against relative lifetime reproductive success for 16 \need {cherry picked traits}, quadratic best fit to the data is shown by dashed lines. \textbf {(b)} Number of traits with inferred type of PRS tail regression and inferred type of selection for 75 UKB traits passing QC. Tail regression is inferred if tail effect is significant at an FDR of 0.05. \textbf {(c)} Spearman rank correlation between standardised mean proxy measures of fitness of individuals in the upper and lower 1\% tails and PRS-test effect size for the corresponding tail across 75 traits in UKB passing QC. \textbf {(d)} \need {not sure this is needed}. \textbf {(e)} Trumpet plots (minor allele frequency v effect size) for simulated data without and with selection. All variants are included in the plot. \textbf {(e)} PRS quantile (in 1\% increments) plotted agaisnt mean trait value in quantile in simulated data without and with selection. PRS calculated from all variants with MAF>1\%. }\relax }{figure.caption.3}{}}
\newlabel{fig:evo@cref}{{[figure][3][]3}{[1][4][]5}}
