\@writefile{lof}{\contentsline {figure}{\numberline {4}{\ignorespaces \footnotesize  {{\bf  Sibling analyses for rare variants of large effect affecting the tails of trait distribution.} \textbf  {(a)} Schematic of relationship of sibling trait values under polygenicity, de novo variants of large effect in one sibling and rare inherited variant of large effect, Mendelian. \textbf  {(b)} SNP heritability estimtaed from {\it  LDscore applied to UKB} plotted against sibling heritability estimated from UKB sibling pairs. \textbf  {(c)} Index sibling trait quantile (in 1\% increments) plotted agaisnt mean trait value of conditional sibling in quantile for four traits with different types of PRS tail regression. \textbf  {(d)} PRS-test P-values plotted against sibling meta test P-values on $-\qopname  \relax o{log}_{10}$ scale for upper and lower tails of X traits. Correlation \textbf  {\leavevmode {\color {red}NEED: and significance}} calculated using Spearman rank correlation.}\relax }}{7}{figure.caption.4}\protected@file@percent }
\newlabel{fig:sib}{{4}{7}{\footnotesize {{\bf Sibling analyses for rare variants of large effect affecting the tails of trait distribution.} \textbf {(a)} Schematic of relationship of sibling trait values under polygenicity, de novo variants of large effect in one sibling and rare inherited variant of large effect, Mendelian. \textbf {(b)} SNP heritability estimtaed from {\it LDscore applied to UKB} plotted against sibling heritability estimated from UKB sibling pairs. \textbf {(c)} Index sibling trait quantile (in 1\% increments) plotted agaisnt mean trait value of conditional sibling in quantile for four traits with different types of PRS tail regression. \textbf {(d)} PRS-test P-values plotted against sibling meta test P-values on $-\log _{10}$ scale for upper and lower tails of X traits. Correlation \need {and significance} calculated using Spearman rank correlation.}\relax }{figure.caption.4}{}}
\newlabel{fig:sib@cref}{{[figure][4][]4}{[1][6][]7}}
\@writefile{lof}{\contentsline {figure}{\numberline {5}{\ignorespaces \footnotesize  {{\bf  Replication results in UKB non-European samples, All of Us European ancestry samples and bootstrap analyses of UKB European samples.} \textbf  {(a)} PRS quantile (in 1\% increments) plotted agaisnt mean trait value in quantile in UKB European ancestry samples, UKB non-European ancestry samples and All Of Us European ancestry samples for four traits with different types of PRS tail regression. \textbf  {(b)} PRS-test tail effect estimates in UKB European ancestry samples, UKB non-European ancestry samples and All of Us Euroepan ancestry samples for 25 traits measured and passing PRS-test quality control in the three cohorts. \textbf  {(c)} Simulated Signal Replication: Increasing larger subsets were sampled and the replicability relative to our UKB result was calculated \textbf  {(d)} Same thing but correlation. \textbf  {(e)}. \textbf  {(f)} PRS-test effect sizes estimated in: UKB European ancestry samples v UKB non-European ancestry samples for X traits passing PRS-test QC in both cohorts. Triangles shaded relative to the non-European sample size for the trait. Pearson correlation shown\textbf  {(g)}. \textbf  {(h)} PRS-test effect sizes estimated in: UKB European ancestry samples v All Of Us European ancestry samples for 24 overlapping traits passing PRS-test QC in both cohorts. Triangles shaded relative to the All of Us sample size for the trait.} \relax }}{8}{figure.caption.5}\protected@file@percent }
\newlabel{fig:rep}{{5}{8}{\footnotesize {{\bf Replication results in UKB non-European samples, All of Us European ancestry samples and bootstrap analyses of UKB European samples.} \textbf {(a)} PRS quantile (in 1\% increments) plotted agaisnt mean trait value in quantile in UKB European ancestry samples, UKB non-European ancestry samples and All Of Us European ancestry samples for four traits with different types of PRS tail regression. \textbf {(b)} PRS-test tail effect estimates in UKB European ancestry samples, UKB non-European ancestry samples and All of Us Euroepan ancestry samples for 25 traits measured and passing PRS-test quality control in the three cohorts. \textbf {(c)} Simulated Signal Replication: Increasing larger subsets were sampled and the replicability relative to our UKB result was calculated \textbf {(d)} Same thing but correlation. \textbf {(e)}. \textbf {(f)} PRS-test effect sizes estimated in: UKB European ancestry samples v UKB non-European ancestry samples for X traits passing PRS-test QC in both cohorts. Triangles shaded relative to the non-European sample size for the trait. Pearson correlation shown\textbf {(g)}. \textbf {(h)} PRS-test effect sizes estimated in: UKB European ancestry samples v All Of Us European ancestry samples for 24 overlapping traits passing PRS-test QC in both cohorts. Triangles shaded relative to the All of Us sample size for the trait.} \relax }{figure.caption.5}{}}
\newlabel{fig:rep@cref}{{[figure][5][]5}{[1][7][]8}}
